# Server
NODE_ENV=development
PORT=5000

# PostgreSQL (local development)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=ssmls_db

# PostgreSQL connection string (used in production on Render)
# Render will set this automatically — leave blank locally
DATABASE_URL=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
